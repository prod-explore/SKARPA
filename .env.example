# ============================================================
#  SKARPA BYTOM — Zmienne środowiskowe
#  Skopiuj jako .env i uzupełnij wartości
# ============================================================

# Aplikacja
NODE_ENV=production
PORT=3000
APP_URL=https://twoja-domena.pl

# Sekrety JWT / sesji (min. 64 losowe znaki każdy)
JWT_SECRET=zmien_na_losowy_sekret_jwt_min_64_znaki_abcdefghijklmnop
JWT_MAGIC_LINK_EXPIRY=15m

# Konta administratorów (oddzielone przecinkiem)
# Magic link logowania do panelu admina będzie wysyłany TYLKO na te adresy
ADMIN_EMAILS=explore.wrld.rld@gmail.com,wspinanie.ue@gmail.com

# Resend — API do wysyłki e-maili (https://resend.com)
# Wygeneruj klucz w: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Adres nadawcy (musi być zweryfikowaną domeną w Resend)
# Na czas testów możesz użyć: onboarding@resend.dev
EMAIL_FROM=Skarpa Bytom <noreply@skarpabytom.pl>

# Baza danych SQLite
DB_PATH=/app/data/skarpa.db

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
MAGIC_LINK_RATE_LIMIT_MAX=5
