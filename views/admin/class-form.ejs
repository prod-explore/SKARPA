<%- include('../partials/head') %>

<div class="admin-layout">
  <aside class="admin-sidebar">
    <%- include('../partials/admin-sidebar-brand') %>
    <nav class="admin-nav">
      <a href="/admin" class="admin-nav-link">📊 Dashboard</a>
      <a href="/admin/calendar" class="admin-nav-link">📅 Kalendarz</a>
      <a href="/admin/classes/new" class="admin-nav-link active">➕ Nowe zajęcia</a>
      <a href="/admin/consents" class="admin-nav-link">📋 Zgody</a>
      <a href="/admin/archive" class="admin-nav-link">🗄️ Archiwum</a>
    </nav>
    <div class="admin-sidebar-footer">
      <form action="/auth/logout" method="POST">
        <button type="submit" class="btn btn--outline btn--sm btn--full">Wyloguj</button>
      </form>
    </div>
  </aside>

  <main class="admin-main">
    <div class="admin-topbar">
      <h1><%= classData ? 'Edytuj zajęcia' : 'Nowe zajęcia' %></h1>
      <a href="/admin" class="btn btn--outline">← Powrót</a>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert--error"><%= error %></div>
    <% } %>

    <div class="admin-form-card">
      <form
        action="<%= classData ? '/admin/classes/' + classData.id : '/admin/classes' %>"
        method="POST"
        class="admin-form"
      >

        <div class="form-row">
          <div class="form-group form-group--wide">
            <label class="form-label">Nazwa zajęć *</label>
            <input type="text" name="name" class="form-input"
                   value="<%= classData ? classData.name : '' %>"
                   placeholder="np. Wspinaczka dla początkujących" required maxlength="120">
          </div>
          <div class="form-group">
            <label class="form-label">Typ zajęć *</label>
            <select name="classType" class="form-input form-select" id="classTypeSelect">
              <option value="adult_only"      <%= (!classData || classData.class_type === 'adult_only')      ? 'selected' : '' %>>🧑 Tylko dorośli</option>
              <option value="adult_and_child"  <%= (classData && classData.class_type === 'adult_and_child')  ? 'selected' : '' %>>👥 Dorośli + Dzieci</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Opis (opcjonalnie)</label>
          <textarea name="description" class="form-input form-textarea"
                    placeholder="Krótki opis zajęć..." maxlength="1000"><%= classData ? classData.description || '' : '' %></textarea>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Data i godzina *</label>
            <input type="datetime-local" name="startTime" class="form-input"
                   value="<%= classData ? classData.start_time.replace(' ', 'T').slice(0,16) : '' %>"
                   required>
          </div>
          <div class="form-group">
            <label class="form-label">Data i godzina zakończenia *</label>
            <input type="datetime-local" name="endTime" class="form-input"
                   value="<%= classData ? new Date(new Date(classData.start_time).getTime() + classData.duration_min*60000 - new Date().getTimezoneOffset()*60000).toISOString().slice(0,16) : '' %>"
                   required>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Maks. uczestników (dorośli) *</label>
            <input type="number" name="maxSpots" class="form-input"
                   value="<%= classData ? classData.max_spots : '' %>"
                   min="1" max="200" placeholder="12" required>
          </div>
          <div class="form-group">
            <label class="form-label">Instruktor (dorośli)</label>
            <input type="text" name="instructor" list="instructors-list" class="form-input"
                   value="<%= classData ? classData.instructor || '' : '' %>"
                   placeholder="Wybierz lub wpisz" maxlength="80">
          </div>
        </div>

        <datalist id="instructors-list">
          <% if (typeof instructors !== 'undefined' && instructors.length > 0) { %>
            <% instructors.forEach(function(inst) { %>
              <option value="<%= inst.first_name %>"></option>
            <% }) %>
          <% } %>
        </datalist>

        <!-- Pola widoczne tylko dla adult_and_child -->
        <div id="childFields" <%- (!classData || classData.class_type !== 'adult_and_child') ? 'style="display: none;"' : 'style="display: block;"' %>>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Maks. dzieci (animacje)</label>
              <input type="number" name="maxChildSpots" class="form-input"
                     value="<%= classData ? classData.max_child_spots || '' : '' %>"
                     min="1" max="200" placeholder="10">
            </div>
            <div class="form-group">
              <label class="form-label">Instruktor (dzieci/animacje)</label>
              <input type="text" name="childInstructor" list="instructors-list" class="form-input"
                     value="<%= classData ? classData.child_instructor || '' : '' %>"
                     placeholder="Wybierz lub wpisz" maxlength="80">
            </div>
          </div>
        </div>

        <!-- Kolor kafelka -->
        <div class="form-row" style="align-items:center;gap:1rem;margin-top:.5rem;">
          <div class="form-group" style="flex:0 0 auto;">
            <label class="form-label">Kolor kafelka</label>
            <input type="color" name="color" class="form-input" style="height:44px;width:80px;padding:4px;cursor:pointer;"
                   value="<%= classData ? (classData.color || '#6366f1') : '#6366f1' %>">
          </div>
          <div class="form-group" style="flex:1;">
            <label class="form-label">Podgląd</label>
            <div id="colorPreview" <%- 'style="height:44px; border-radius:8px; padding:0 16px; display:flex; align-items:center; font-weight:600; font-size:0.9rem; color:#fff; background-color: ' + (classData && classData.color ? classData.color : '#6366f1') + ';"' %>>
              Podgląd zajęć
            </div>
          </div>
        </div>

        <!-- Lista rezerwowa -->
        <div class="form-group" style="margin-top:.5rem;">
          <label class="form-label" style="display:flex;align-items:center;gap:.75rem;cursor:pointer;">
            <input type="checkbox" name="waitingListEnabled" id="waitingListEnabled" value="1"
                   style="width:18px;height:18px;cursor:pointer;accent-color:#2d5a3d;"
                   <%- (classData && classData.waiting_list_enabled) ? 'checked' : '' %>>
            <span>🕐 Włącz listę rezerwową (tylko dorośli, maks. 15 miejsc)</span>
          </label>
        </div>

        <div class="form-actions">
          <a href="/admin" class="btn btn--outline">Anuluj</a>
          <button type="submit" class="btn btn--primary btn--lg">
            <%= classData ? 'Zapisz zmiany' : 'Dodaj zajęcia' %> →
          </button>
        </div>

      </form>
    </div>
  </main>
</div>

<script>
  // Pokaz/ukryj pola dzieci w zależności od typu
  document.getElementById('classTypeSelect').addEventListener('change', function() {
    document.getElementById('childFields').style.display =
      this.value === 'adult_and_child' ? '' : 'none';
  });

  // Podgląd koloru na żywo
  const colorInput = document.querySelector('input[name="color"]');
  const colorPreview = document.getElementById('colorPreview');
  if (colorInput && colorPreview) {
    colorInput.addEventListener('input', function() {
      colorPreview.style.background = this.value;
    });
  }

  // Pokaż/ukryj pola listy rezerwowej
  const waitingCheckbox = document.getElementById('waitingListEnabled');
  const waitingFields   = document.getElementById('waitingListFields');
  if (waitingCheckbox && waitingFields) {
    waitingCheckbox.addEventListener('change', function() {
      waitingFields.style.display = this.checked ? '' : 'none';
    });
  }
</script>
<script src="/js/main.js"></script>
</body>
</html>
