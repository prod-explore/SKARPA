<%- include('../partials/head') %>

<div class="admin-layout">

  <!-- Sidebar -->
  <aside class="admin-sidebar">
    <%- include('../partials/admin-sidebar-brand') %>
    <nav class="admin-nav">
      <a href="/admin" class="admin-nav-link active">📊 Dashboard</a>
      <a href="/admin/calendar" class="admin-nav-link">📅 Kalendarz</a>
      <a href="/admin/classes/new" class="admin-nav-link">➕ Nowe zajęcia</a>
      <a href="/admin/consents" class="admin-nav-link">📋 Zgody (<%= typeof pendingConsents !== 'undefined' ? pendingConsents : 0 %>)</a>
      <a href="/admin/archive" class="admin-nav-link">🗄️ Archiwum</a>
    </nav>
    <div class="admin-sidebar-footer">
      <div class="admin-user-info">
        <span>👤 <%= user.email %></span>
      </div>
      <form action="/auth/logout" method="POST">
        <button type="submit" class="btn btn--outline btn--sm btn--full">Wyloguj</button>
      </form>
    </div>
  </aside>

  <!-- Main content -->
  <main class="admin-main">
    <div class="admin-topbar">
      <h1>Panel Administracyjny</h1>
      <div class="admin-topbar-actions">
        <form action="/admin/clone-week" method="POST" style="display:inline-flex; align-items:center; gap:0.5rem;"
              onsubmit="return confirm('Czy na pewno chcesz sklonować zajęcia z bieżącego tygodnia na wybrany tydzień?');">
          <select name="weeksAhead" class="form-control" style="width: auto; padding: 0.4rem; font-size: 0.9rem;">
            <option value="1">1 tydzień w przód</option>
            <option value="2">2 tygodnie w przód</option>
            <option value="3">3 tygodnie w przód</option>
            <option value="4">4 tygodnie w przód</option>
          </select>
          <button type="submit" class="btn btn--outline">📋 Klonuj</button>
        </form>
        <a href="/admin/classes/new" class="btn btn--primary">+ Nowe zajęcia</a>
      </div>
    </div>

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert--success"><%= success %></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert--error"><%= error %></div>
    <% } %>

    <!-- Statystyki -->
    <div class="admin-stats">
      <div class="admin-stat-card">
        <div class="admin-stat-num"><%= stats.upcomingCount %></div>
        <div class="admin-stat-label">Nadchodzące zajęcia</div>
      </div>
      <div class="admin-stat-card">
        <div class="admin-stat-num"><%= stats.totalClasses %></div>
        <div class="admin-stat-label">Wszystkie zajęcia</div>
      </div>
      <div class="admin-stat-card">
        <div class="admin-stat-num"><%= stats.totalParticipants %></div>
        <div class="admin-stat-label">Łącznie uczestników</div>
      </div>
      <div class="admin-stat-card">
        <div class="admin-stat-num"><%= stats.qrScans %></div>
        <div class="admin-stat-label">📱 Skany QR z ulotki</div>
      </div>
    </div>

    <!-- Info o manualnych zapisach -->
    <div class="admin-info-box">
      <div class="admin-info-icon">📧</div>
      <div>
        <strong>Manualne zapisy awaryjne</strong>
        <p>
          W przypadku problemów technicznych z systemem, uczestnicy mogą zapisywać się
          bezpośrednio przez e-mail:
          <a href="mailto:wspinanie.ue@gmail.com" class="admin-email-link">wspinanie.ue@gmail.com</a>.
        </p>
      </div>
    </div>

    <!-- Tabela zajęć -->
    <div class="admin-section">
      <h2>Wszystkie zajęcia</h2>

      <% if (classes.length === 0) { %>
        <div class="empty-state">
          <p>Brak zajęć. <a href="/admin/classes/new">Dodaj pierwsze.</a></p>
        </div>
      <% } else { %>
        <div class="admin-table-wrapper">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Nazwa</th>
                <th>Data i godzina</th>
                <th>Typ</th>
                <th>Dorośli</th>
                <th>Dzieci</th>
                <th>Status</th>
                <th>Akcje</th>
              </tr>
            </thead>
            <tbody>
              <% classes.forEach(cls => { %>
                <%
                  const date = new Date(cls.start_time);
                  const dateStr = date.toLocaleDateString('pl-PL', { day: 'numeric', month: 'short', year: 'numeric' });
                  const endDate = new Date(date.getTime() + (cls.duration_min * 60000));
                  const endTimeStr = endDate.toLocaleTimeString('pl-PL', { hour: '2-digit', minute: '2-digit' });
                  const timeStr = date.toLocaleTimeString('pl-PL', { hour: '2-digit', minute: '2-digit' });
                  const isPast = date < new Date();
                  const isEnded = endDate < new Date();
                  const adultTaken = cls.adult_taken || 0;
                  const childTaken = cls.child_taken || 0;
                  const adultPct = Math.round(adultTaken / cls.max_spots * 100);
                  const childPct = cls.max_child_spots > 0 ? Math.round(childTaken / cls.max_child_spots * 100) : 0;
                %>
                <tr class="<%= cls.is_cancelled ? 'row--cancelled' : isPast ? 'row--past' : '' %>">
                  <td>
                    <strong><%= cls.name %></strong>
                    <% if (cls.instructor) { %><br><small>👤 <%= cls.instructor %></small><% } %>
                    <% if (cls.class_type === 'adult_and_child' && cls.child_instructor) { %><br><small>👦 <%= cls.child_instructor %></small><% } %>
                  </td>
                  <td><%= dateStr %><br><small><%= timeStr %> - <%= endTimeStr %></small></td>
                  <td>
                    <span class="badge-cat badge-cat--<%= cls.class_type === 'adult_and_child' ? 'mixed' : 'adults' %>">
                      <%= cls.class_type === 'adult_and_child' ? 'D+Dz' : 'Dorośli' %>
                    </span>
                  </td>
                  <td>
                    <div class="mini-bar-wrap">
                      <div class="mini-bar">
                        <div class="mini-bar-fill" <%- `style="width:${adultPct}%"` %>></div>
                      </div>
                      <span><%= adultTaken %>/<%= cls.max_spots %></span>
                    </div>
                  </td>
                  <td>
                    <% if (cls.class_type === 'adult_and_child' && cls.max_child_spots > 0) { %>
                    <div class="mini-bar-wrap">
                      <div class="mini-bar">
                        <div class="mini-bar-fill" <%- `style="width:${childPct}%"` %>></div>
                      </div>
                      <span><%= childTaken %>/<%= cls.max_child_spots %></span>
                    </div>
                    <% } else { %>
                      <span style="color:#999;">—</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (cls.is_cancelled) { %>
                      <span class="badge badge--cancelled">Odwołane</span>
                    <% } else if (isEnded) { %>
                      <span class="badge badge--past">Zakończone</span>
                    <% } else if (isPast && !isEnded) { %>
                      <span class="badge badge--active" style="background-color: var(--primary);">W trakcie</span>
                    <% } else { %>
                      <span class="badge badge--active">Aktywne</span>
                    <% } %>
                  </td>
                  <td class="admin-actions">
                    <a href="/admin/classes/<%= cls.id %>/attendance" class="btn btn--outline btn--xs">
                      👥 Lista
                    </a>
                    <a href="/admin/classes/<%= cls.id %>/edit" class="btn btn--outline btn--xs">
                      ✏️ Edytuj
                    </a>
                    <% if (!cls.is_cancelled && !isPast) { %>
                    <form action="/admin/classes/<%= cls.id %>/cancel" method="POST" style="display:inline;"
                          data-confirm="Odwołać te zajęcia?">
                      <button type="submit" class="btn btn--warning btn--xs">⚠️ Odwołaj</button>
                    </form>
                    <% } %>
                    <form action="/admin/classes/<%= cls.id %>/archive" method="POST" style="display:inline;"
                          data-confirm="Przenieść te zajęcia do archiwum?">
                      <button type="submit" class="btn btn--danger btn--xs">🗄️ Archiwizuj</button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

  </main>
</div>

<script src="/js/main.js"></script>
</body>
</html>
