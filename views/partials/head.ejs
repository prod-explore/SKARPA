<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | <%= appName %></title>
  <meta name="description" content="Darmowe zajęcia wspinaczkowe — projekt dofinansowany z funduszy Unii Europejskiej. Rozpocznij swoją przygodę ze wspinaczką już dziś!">
  <meta name="theme-color" content="#1a1d17">

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://fw.skarpa.bytom.pl/">
  <meta property="og:title" content="<%= title %> | <%= appName %>">
  <meta property="og:description" content="Zapisz się na darmowe zajęcia wspinaczkowe. Profesjonalni instruktorzy, sprzęt w cenie i świetna zabawa!">
  <meta property="og:image" content="/images/fw-logo.png">

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:title" content="<%= title %> | <%= appName %>">
  <meta property="twitter:description" content="Zapisz się na darmowe zajęcia wspinaczkowe.">
  <meta property="twitter:image" content="/images/fw-logo.png">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="icon" href="/images/fw-logo.png" type="image/png" sizes="any">
  <link rel="apple-touch-icon" href="/images/fw-logo.png">
</head>
<body>
<%- include('cookie-banner') %>
