<!-- FOOTER -->
<footer class="footer">
  <div class="footer-main" style="padding: 3rem 0 1rem 0; background: var(--bg);">
    <div class="footer-inner container" style="display:flex; flex-wrap:wrap; gap:3rem; justify-content:space-between;">
      <div class="footer-col">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:0.75rem;">
          <img src="/images/fw-logo.png" alt="" width="44" height="44" decoding="async" style="height:44px;width:auto;border-radius:6px;flex-shrink:0;">
          <div class="footer-brand" style="font-family:'Barlow Condensed', sans-serif; font-weight:800; color:var(--primary-dark); font-size:1.25rem; margin:0;">Zajęcia wspinaczkowe</div>
        </div>
        <p class="footer-desc" style="font-size:0.9rem; color:var(--text-muted); max-width:280px;">System rezerwacji darmowych zajęć wspinaczkowych w ramach unijnego projektu aktywizacji.</p>
      </div>
      <div class="footer-col" style="display:flex; flex-direction:column; gap:0.5rem;">
        <h4 style="font-family:'Barlow Condensed', sans-serif; font-size:1.1rem; color:var(--primary-dark); margin-bottom: 0.5rem;">Przydatne linki</h4>
        <a href="/" style="font-size:0.9rem; color:var(--text-muted);">Strona główna</a>
        <a href="/calendar" style="font-size:0.9rem; color:var(--text-muted);">Kalendarz zajęć</a>
        <a href="/terms" style="font-size:0.9rem; color:var(--text-muted);">Regulamin</a>
        <a href="/privacy" style="font-size:0.9rem; color:var(--text-muted);">Polityka Prywatności</a>
        <a href="/cookies" style="font-size:0.9rem; color:var(--text-muted);">Polityka Cookies</a>
      </div>
      <div class="footer-col" style="display:flex; flex-direction:column; gap:0.5rem;">
        <h4 style="font-family:'Barlow Condensed', sans-serif; font-size:1.1rem; color:var(--primary-dark); margin-bottom: 0.5rem;">Miejsce zajęć</h4>
        <p style="font-size:0.9rem; color:var(--text-muted); margin:0;">ul. W. Kilara 33<br>Bytom - Rozbark</p>
        <p style="margin:0;"><a href="mailto:wspinanie.ue@gmail.com" style="font-size:0.9rem; color:var(--primary); font-weight:600;">wspinanie.ue@gmail.com</a></p>
      </div>
    </div>
    <div class="footer-bottom container" style="text-align:center; padding-top:2.5rem; margin-top:2rem; border-top:1px solid var(--border);">
      <p style="font-size:0.85rem; color:var(--text-light); margin:0;">© <%= currentYear %> System Rezerwacji Zajęć. Wszystkie prawa zastrzeżone.</p>
    </div>
  </div>
</footer>


