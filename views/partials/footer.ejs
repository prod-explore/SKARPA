<!-- FOOTER -->
<footer class="footer">
  <!-- Baner UE stylizowany -->
  <div class="eu-bar" style="background:#fff; border-top:1px solid #e2e8f0; border-bottom:1px solid #e2e8f0; padding:1.5rem 0;">
    <div class="container eu-bar-content">
      <div class="eu-logos-grid" style="display:flex; gap:1.5rem; justify-content:flex-start; flex-wrap:wrap; opacity:0.9;">
        <div class="eu-logo-item" style="border-right:1px solid #cbd5e1; padding-right:1.5rem;">
            <span style="font-weight: 800; font-size: 0.95rem; color:#0e4e96;">Fundusze<br>Europejskie</span>
        </div>
        <div class="eu-logo-item" style="border-right:1px solid #cbd5e1; padding-right:1.5rem;">
            <span style="font-weight: 600; font-size: 0.95rem; color:#1e1e1e;">Rzeczpospolita<br>Polska</span>
        </div>
        <div class="eu-logo-item">
            <span style="font-weight: 800; font-size: 0.95rem; color:#0e4e96;">Unia Europejska<br><span style="font-weight: 500; font-size:0.8rem; color:#1e1e1e;">Europejski Fundusz Społeczny</span></span>
        </div>
      </div>
      <p class="eu-text" style="font-size:0.80rem; margin-top:1.5rem; color:#64748b; max-width: 800px; line-height: 1.5;">
        Projekt „Darmowe Zajęcia Wspinaczkowe" jest dofinansowany ze środków
        Unii Europejskiej w ramach Europejskiego Funduszu Społecznego.
      </p>
    </div>
  </div>

  <div class="footer-main" style="padding: 3rem 0 1rem 0; background: var(--bg);">
    <div class="footer-inner container" style="display:flex; flex-wrap:wrap; gap:3rem; justify-content:space-between;">
      <div class="footer-col">
        <div class="footer-brand" style="font-family:'Barlow Condensed', sans-serif; font-weight:800; color:var(--primary-dark); font-size:1.4rem; margin-bottom: 0.5rem;">🧗 ZAJĘCIA WSPINACZKOWE</div>
        <p class="footer-desc" style="font-size:0.9rem; color:var(--text-muted); max-width:280px;">System rezerwacji darmowych zajęć wspinaczkowych w ramach unijnego projektu aktywizacji.</p>
      </div>
      <div class="footer-col" style="display:flex; flex-direction:column; gap:0.5rem;">
        <h4 style="font-family:'Barlow Condensed', sans-serif; font-size:1.1rem; color:var(--primary-dark); margin-bottom: 0.5rem;">Przydatne linki</h4>
        <a href="/" style="font-size:0.9rem; color:var(--text-muted);">Strona główna</a>
        <a href="/calendar" style="font-size:0.9rem; color:var(--text-muted);">Kalendarz zajęć</a>
        <a href="/login" style="font-size:0.9rem; color:var(--text-muted);">Rejestracja / Logowanie</a>
      </div>
      <div class="footer-col" style="display:flex; flex-direction:column; gap:0.5rem;">
        <h4 style="font-family:'Barlow Condensed', sans-serif; font-size:1.1rem; color:var(--primary-dark); margin-bottom: 0.5rem;">Dokumenty</h4>
        <a href="/regulamin" style="font-size:0.9rem; color:var(--text-muted);">Regulamin i zasady</a>
        <a href="/polityka-prywatnosci" style="font-size:0.9rem; color:var(--text-muted);">Polityka prywatności</a>
      </div>
      <div class="footer-col" style="display:flex; flex-direction:column; gap:0.5rem;">
        <h4 style="font-family:'Barlow Condensed', sans-serif; font-size:1.1rem; color:var(--primary-dark); margin-bottom: 0.5rem;">Miejsce zajęć</h4>
        <p style="font-size:0.9rem; color:var(--text-muted); margin:0;">ul. W. Kilara 33<br>Bytom - Rozbark</p>
        <p style="margin:0;"><a href="mailto:wspinanie.ue@gmail.com" style="font-size:0.9rem; color:var(--primary); font-weight:600;">wspinanie.ue@gmail.com</a></p>
      </div>
    </div>
    <div class="footer-bottom container" style="text-align:center; padding-top:2.5rem; margin-top:2rem; border-top:1px solid var(--border);">
      <p style="font-size:0.85rem; color:var(--text-light); margin:0;">© <%= currentYear %> System Rezerwacji Zajęć. Wszystkie prawa zastrzeżone.</p>
    </div>
  </div>
</footer>
