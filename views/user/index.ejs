<%- include('../partials/head') %>

  <%- include('../partials/navbar', { user: user }) %>

    <!-- HERO -->
    <section class="hero" id="hero-panel">
      <div class="hero-bg"></div>
      <div class="hero-content">

        <h1 class="hero-title">
          Fantastyczne<br>
          <span class="hero-title--accent">Wspinanie</span>
        </h1>
        <p class="hero-subtitle">
          Darmowe zajęcia wspinaczkowe dla uczestników projektu.<br>
          Zarządzaj swoimi rezerwacjami na zajęcia wspinaczkowe.
        </p>
        <div class="hero-actions">
          <% if (typeof user !=='undefined' && user) { %>
            <a href="/dashboard" class="btn btn--primary btn--lg">Przejdź do panelu →</a>
            <% } else { %>
              <a href="/login" class="btn btn--primary btn--lg">Zaloguj się →</a>
              <% } %>
        </div>

      </div>
    </section>


    <!-- BANER AWARYJNY — zapis przez e-mail -->
    <div class="emergency-contact-bar">
      <div class="container">
        <span class="emergency-icon">📧</span>
        <span>Problemy z systemem? Zapisz się bezpośrednio przez e-mail:</span>
        <a href="mailto:wspinanie.ue@gmail.com" class="emergency-link">wspinanie.ue@gmail.com</a>
      </div>
    </div>




    <!-- SEKCJA: TYGODNIOWY WIDOK ZAJĘĆ -->
    <section class="section" id="section-calendar">
      <div class="container container--wide">
        <div class="section-header">
          <span class="section-tag">Plan tygodnia</span>
          <h2>Zajęcia w tym tygodniu</h2>
        </div>

        <div class="week-nav" style="margin-bottom:1.5rem;">
          <span class="week-nav-label">
            <%= weekStart.toLocaleDateString('pl-PL', { day: 'numeric' , month: 'long' }) %> –
              <%= weekEnd.toLocaleDateString('pl-PL', { day: 'numeric' , month: 'long' , year: 'numeric' }) %>
          </span>
          <a href="/calendar" class="btn btn--outline btn--sm">Pełny kalendarz →</a>
        </div>

        <% /*==========PRE-PROCESSING: group events by day, detect overlaps==========*/ const PX_PER_HOUR=64; const
          totalHours=END_HOUR - START_HOUR; /* Build per-day arrays */ const dayEvents=[[], [], [], [], [], [], []];
          weekClasses.forEach(cls=> {
          const st = new Date(cls.start_time);
          const dayInWeek = Math.round(
          (new Date(weekStart.toDateString()) - new Date(st.toDateString())) / 86400000
          ) * -1;
          if (dayInWeek < 0 || dayInWeek> 6) return;

            const startMin = st.getHours() * 60 + st.getMinutes();
            const endMin = startMin + (cls.duration_min || 60);
            const offsetMin = startMin - START_HOUR * 60;
            if (offsetMin < 0) return; const et=new Date(st.getTime() + (cls.duration_min || 60) * 60000); const
              timeStr=st.toLocaleTimeString('pl-PL', { hour: '2-digit' , minute: '2-digit' }); const
              endStr=et.toLocaleTimeString('pl-PL', { hour: '2-digit' , minute: '2-digit' }); const
              adultLeft=cls.max_spots - (cls.adult_taken || 0); const childLeft=cls.class_type==='adult_and_child' ?
              (cls.max_child_spots - (cls.child_taken || 0)) : 0; dayEvents[dayInWeek].push({ id: cls.id, name:
              cls.name, instructor: cls.instructor || '' , child_instructor: cls.child_instructor || '' , description:
              cls.description || '' , class_type: cls.class_type, is_cancelled: cls.is_cancelled, max_spots:
              cls.max_spots, max_child_spots: cls.max_child_spots, duration_min: cls.duration_min || 60, color:
              cls.color || '#6366f1' , startMin, endMin, offsetMin, timeStr, endStr, adultLeft, childLeft, isFull:
              adultLeft <=0, col: 0, totalCols: 1 }); }); /* Overlap detection: greedy column assignment per day */
              dayEvents.forEach(events=> {
              events.sort((a, b) => a.startMin - b.startMin || a.endMin - b.endMin);

              const columns = []; /* columns[c] = [events...] */
              events.forEach(ev => {
              let placed = false;
              for (let c = 0; c < columns.length; c++) { const last=columns[c][columns[c].length - 1]; if (last.endMin
                <=ev.startMin) { columns[c].push(ev); ev.col=c; placed=true; break; } } if (!placed) {
                ev.col=columns.length; columns.push([ev]); } }); /* Compute totalCols per overlap cluster */
                events.forEach(ev=> {
                let maxCol = ev.col;
                events.forEach(other => {
                if (other.startMin < ev.endMin && other.endMin> ev.startMin) {
                  if (other.col > maxCol) maxCol = other.col;
                  }
                  });
                  ev.totalCols = maxCol + 1;
                  });
                  });
                  %>

                  <!-- ========== WEEKLY GRID ========== -->
                  <div class="kcal-wrapper">
                    <!-- Scrollable area: headers + body together -->
                    <div class="kcal-scroll">
                      <!-- Header row: gutter + 7 days -->
                      <div class="kcal-header">
                        <div class="kcal-gutter-hd"></div>
                        <% for (let d=0; d < 7; d++) { const day=new Date(weekStart); day.setDate(weekStart.getDate() +
                          d); const isToday=day.toDateString()===new Date().toDateString(); %>
                          <div class="kcal-day-hd <%= isToday ? 'kcal-day-hd--today' : '' %>">
                            <span class="kcal-day-name">
                              <%= day.toLocaleDateString('pl-PL', { weekday: 'short' }) %>
                            </span>
                            <span class="kcal-day-num <%= isToday ? 'kcal-day-num--today' : '' %>">
                              <%= day.getDate() %>
                            </span>
                          </div>
                          <% } %>
                      </div>
                      <div class="kcal-body" <%- `style="height:calc(var(--hh) * ${totalHours});"` %>>
                        <!-- Time gutter -->
                        <div class="kcal-gutter">
                          <% for (let h=START_HOUR; h < END_HOUR; h++) { %>
                            <div class="kcal-gutter-label" <%- `style="top:calc(var(--hh) * ${h - START_HOUR});"` %>>
                              <%= String(h).padStart(2, '0' ) %>:00
                            </div>
                            <% } %>
                        </div>

                        <!-- 7 day columns -->
                        <div class="kcal-cols">
                          <% for (let d=0; d < 7; d++) { const day=new Date(weekStart); day.setDate(weekStart.getDate()
                            + d); const isToday=day.toDateString()===new Date().toDateString(); %>
                            <div class="kcal-col <%= isToday ? 'kcal-col--today' : '' %>">
                              <!-- Hour gridlines -->
                              <% for (let h=0; h <=totalHours; h++) { %>
                                <div class="kcal-gridline" <%- `style="top:calc(var(--hh) * ${h});"` %>></div>
                                <% } %>
                                  <!-- Half-hour gridlines -->
                                  <% for (let h=0; h < totalHours; h++) { %>
                                    <div class="kcal-gridline kcal-gridline--half"
                                      <%- `style="top:calc(var(--hh) * ${h} + var(--hh) * 0.5);"` %>></div>
                                    <% } %>

                                      <!-- Events for this day -->
                                      <% dayEvents[d].forEach(ev=> {
                                        const topMult = (ev.offsetMin / 60);
                                        const heightMult = (ev.duration_min / 60);
                                        const colW = 100 / ev.totalCols;
                                        const leftPct = ev.col * colW;
                                        %>
                                        <div
                                          class="kcal-ev <%= ev.isFull ? 'kcal-ev--full' : '' %> <%= ev.is_cancelled ? 'kcal-ev--cancelled' : '' %>"
                                          <%- `style="top:calc(var(--hh) * ${topMult.toFixed(4)}); height:calc(var(--hh) * ${heightMult.toFixed(4)}); left:calc(${leftPct.toFixed(2)}% + 2px); width:calc(${colW.toFixed(2)}% - 4px); --ev-color:${ev.color};"` %> data-id="<%= ev.id %>" data-name="<%= ev.name %>"
                                          data-time="<%= ev.timeStr %> – <%= ev.endStr %>"
                                          data-instructor="<%= ev.instructor %>"
                                          data-child-instructor="<%= ev.child_instructor %>"
                                          data-description="<%= ev.description %>" data-adult-left="<%= ev.adultLeft %>"
                                          data-adult-max="<%= ev.max_spots %>" data-child-left="<%= ev.childLeft %>"
                                          data-child-max="<%= ev.max_child_spots %>" data-type="<%= ev.class_type %>"
                                          data-cancelled="<%= ev.is_cancelled ? '1' : '0' %>" role="button" tabindex="0"
                                          aria-label="<%= ev.name %>">
                                          <span class="kcal-ev-name">
                                            <%= ev.name %>
                                          </span>
                                          <span class="kcal-ev-time">
                                            <%= ev.timeStr %> – <%= ev.endStr %>
                                          </span>
                                          <% if (ev.instructor) { %>
                                            <span class="kcal-ev-instr">
                                              <%= ev.instructor %>
                                            </span>
                                            <% } %>
                                              <% if (ev.isFull) { %>
                                                <span class="kcal-ev-badge">Brak miejsc</span>
                                                <% } else if (ev.is_cancelled) { %>
                                                  <span class="kcal-ev-badge">Odwołane</span>
                                                  <% } %>
                                        </div>
                                        <% }); %>
                            </div>
                            <% } %>
                        </div>
                      </div>
                    </div>
                  </div>
      </div>
    </section>

    <!-- SEKCJA: INSTRUKCJE -->
    <section class="section section--light">
      <div class="container container--narrow">
        <div class="section-header">
          <span class="section-tag">Zasady uczestnictwa</span>
          <h2>Jak działają zapisy?</h2>
        </div>
        <ul class="instruction-list">
          <li>
            <strong>Proste zapisy:</strong> Załóż konto i zapisz siebie lub dodatkowe osoby (w tym dzieci)
            na wybrany termin, dopóki są wolne miejsca. Jeśli z jakiegoś powodu musisz zrezygnować
            — pamiętaj, aby wypisać się z zajęć.
            Maksymalnie możesz zapisać oprócz siebie <strong>4 inne osoby</strong>.
          </li>
          <li>
            <strong>Osoba niepełnoletnia:</strong> żeby osoba niepełnoletnia mogła samodzielnie
            rejestrować się na zajęcia, musi najpierw dostarczyć podpisany przez rodzica
            formularz unijny dostępny w recepcji. Następnie zostanie zaakceptowana przez administratora.
            Rodzic lub pełnoletni opiekun może zapisać dziecko samodzielnie przez swoje konto
            — bez konieczności dodatkowej zgody.
          </li>
          <li>
            <strong>Pytania?</strong> Skontaktuj się z nami:
            <a href="mailto:wspinanie.ue@gmail.com">wspinanie.ue@gmail.com</a>
          </li>
        </ul>
      </div>
    </section>

    <!-- SEKCJA: MAPA -->
    <section class="section section--map">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">Nasza lokalizacja</span>
          <h2>Gdzie odbywają się zajęcia?</h2>
        </div>
        <div class="map-wrapper">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2546.284345570785!2d18.928098576550873!3d50.34260167157167!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4716d34cb979d97f%3A0x55caf8fee26a2016!2sSkarpa%20Bytom%20Rozbark!5e0!3m2!1spl!2spl!4v1776429791392!5m2!1spl!2spl"
            width="100%" height="400" style="border:0;border-radius:12px;" allowfullscreen="" loading="lazy"
            referrerpolicy="no-referrer-when-downgrade" title="Skarpa Bytom Rozbark">
          </iframe>
          <div class="map-info-card">
            <h4>📍 Miejsce zajęć</h4>
            <p>Skarpa Bytom<br>ul. Wojciecha Kilara 33, Bytom Rozbark</p>
            <a href="https://maps.app.goo.gl/n8tuHMmicivzHh2f6" target="_blank" rel="noopener"
              class="btn btn--primary btn--sm">
              Nawiguj w Google Maps →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section section--cta">
      <div class="container">
        <div class="cta-box">
          <div class="cta-content">
            <h2>Gotowy na zajęcia?</h2>
            <p>Zaloguj się do panelu i zarządzaj zapisanymi osobami.</p>
          </div>
          <div class="cta-actions">
            <% if (typeof user !=='undefined' && user) { %>
              <a href="/dashboard" class="btn btn--white btn--lg">Twój Panel →</a>
              <% } else { %>
                <a href="/login" class="btn btn--white btn--lg">Zaloguj się / Zarejestruj →</a>
                <% } %>
          </div>
        </div>
      </div>
    </section>

    <%- include('../partials/footer') %>

      <!-- MODAL SZCZEGÓŁÓW (index) -->
      <div id="classModal" class="cal-modal-overlay" aria-modal="true" role="dialog" style="display:none;">
        <div class="cal-modal">
          <button class="cal-modal-close" id="modalClose" aria-label="Zamknij">✕</button>
          <div class="cal-modal-accent" id="modalAccent"></div>
          <div class="cal-modal-body">
            <h2 class="cal-modal-title" id="modalTitle"></h2>
            <p class="cal-modal-time" id="modalTime"></p>
            <div class="cal-modal-meta" id="modalMeta"></div>
            <p class="cal-modal-desc" id="modalDesc"></p>
            <div class="cal-modal-spots" id="modalSpots"></div>
            <div class="cal-modal-actions" id="modalActions"></div>
          </div>
        </div>
      </div>

      <script>
        const modal = document.getElementById('classModal');
        const modalClose = document.getElementById('modalClose');
        const modalAccent = document.getElementById('modalAccent');
        const modalTitle = document.getElementById('modalTitle');
        const modalTime = document.getElementById('modalTime');
        const modalMeta = document.getElementById('modalMeta');
        const modalDesc = document.getElementById('modalDesc');
        const modalSpots = document.getElementById('modalSpots');
        const modalActions = document.getElementById('modalActions');
        const isLoggedIn = ('<%= typeof user !== "undefined" && user ? "true" : "false" %>' === 'true');

        function openModal(el) {
          const d = el.dataset;
          const isCancelled = d.cancelled === '1';
          const adultLeft = parseInt(d.adultLeft);
          const childLeft = parseInt(d.childLeft);
          const isFull = adultLeft <= 0;
          const isMixed = d.type === 'adult_and_child';

          modalAccent.style.background = getComputedStyle(el).getPropertyValue('--ev-color');
          modalTitle.textContent = d.name;
          modalTime.textContent = d.time;

          let meta = '';
          if (d.instructor) meta += `<span>👤 ${d.instructor}</span>`;
          if (d.childInstructor) meta += `<span>🧒 Animacje: ${d.childInstructor}</span>`;
          meta += `<span>${isMixed ? '👥 Dorośli + Dzieci' : '🧑 Tylko dorośli'}</span>`;
          modalMeta.innerHTML = meta;

          const fullDesc = d.description || '';
          if (fullDesc.length > 250) {
            const shortDesc = fullDesc.substring(0, 250) + '... ';
            modalDesc.innerHTML = '';
            const textSpan = document.createElement('span');
            textSpan.textContent = shortDesc;
            const moreBtn = document.createElement('a');
            moreBtn.textContent = 'Pokaż więcej';
            moreBtn.style.cursor = 'pointer';
            moreBtn.style.color = 'var(--brand)';
            moreBtn.style.fontWeight = '700';
            moreBtn.onclick = () => {
              textSpan.textContent = fullDesc;
              moreBtn.style.display = 'none';
            };
            modalDesc.appendChild(textSpan);
            modalDesc.appendChild(moreBtn);
            modalDesc.style.display = '';
          } else {
            modalDesc.textContent = fullDesc;
            modalDesc.style.display = fullDesc ? '' : 'none';
          }

          let spots = `<div class="modal-spots-row">`;
          spots += `<span class="modal-spot-label ${adultLeft <= 3 ? 'low' : ''}">🧑 Dorośli: ${adultLeft} wolnych</span>`;
          if (isMixed) spots += `<span class="modal-spot-label ${childLeft <= 3 ? 'low' : ''}">👦 Dzieci: ${childLeft} wolnych</span>`;
          spots += `</div>`;
          modalSpots.innerHTML = spots;

          let actions = '';
          if (isCancelled) actions = `<span class="badge badge--full">Zajęcia odwołane</span>`;
          else if (isFull) actions = `<span class="badge badge--full">Brak miejsc</span>`;
          else if (isLoggedIn) actions = `<a href="/book/${d.id}" class="btn btn--primary btn--lg">Zapisz się →</a>`;
          else actions = `<a href="/login?next=/book/${d.id}" class="btn btn--primary btn--lg">Zaloguj się, by się zapisać →</a>`;
          modalActions.innerHTML = actions;

          modal.style.display = 'flex';
          document.body.style.overflow = 'hidden';
          modalClose.focus();
        }

        function closeModal() {
          modal.style.display = 'none';
          document.body.style.overflow = '';
        }

        document.querySelectorAll('.kcal-ev').forEach(el => {
          el.addEventListener('click', () => openModal(el));
          el.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openModal(el); } });
        });

        modalClose.addEventListener('click', closeModal);
        modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
      </script>

      <script src="/js/main.js"></script>
      </body>

      </html>