<%- include('../partials/head') %>

<%- include('../partials/navbar', { user: user }) %>

<!-- HERO -->
<section class="hero" id="hero-panel">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <div class="hero-badge">🇪🇺 Projekt UE — Bezpłatnie</div>
    <h1 class="hero-title">
      Panel<br>
      <span class="hero-title--accent">Uczestnika</span>
    </h1>
    <p class="hero-subtitle">
      Darmowe zajęcia wspinaczkowe dla uczestników projektu.<br>
      Zarządzaj swoimi rezerwacjami na zajęcia w Skarpa Bytom.
    </p>
    <div class="hero-actions">
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="/dashboard" class="btn btn--primary btn--lg">Przejdź do panelu →</a>
      <% } else { %>
        <a href="/login" class="btn btn--primary btn--lg">Zaloguj się →</a>
      <% } %>
      <a href="#o-projekcie" class="btn btn--outline btn--lg">O projekcie</a>
    </div>
    <div class="hero-stats">
      <div class="hero-stat">
        <span class="hero-stat-num">0 zł</span>
        <span class="hero-stat-label">Koszt udziału</span>
      </div>
    </div>
  </div>
</section>


<!-- BANER AWARYJNY — zapis przez e-mail -->
<div class="emergency-contact-bar">
  <div class="container">
    <span class="emergency-icon">📧</span>
    <span>Problemy z systemem? Zapisz się bezpośrednio przez e-mail:</span>
    <a href="mailto:wspinanie.ue@gmail.com" class="emergency-link">wspinanie.ue@gmail.com</a>
  </div>
</div>

<!-- SEKCJA: O PROJEKCIE -->
<section class="section section--light" id="o-projekcie">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Dlaczego warto</span>
      <h2>Wspinaczka dla każdego</h2>
      <p>Projekt dofinansowany z Unii Europejskiej umożliwia bezpłatny dostęp do profesjonalnych zajęć wspinaczkowych.</p>
    </div>

    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">🆓</div>
        <h3>Całkowicie bezpłatnie</h3>
        <p>Zajęcia są w 100% finansowane ze środków UE. Nie pobieramy żadnych opłat od uczestników.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">👨‍👩‍👧‍👦</div>
        <h3>Dla całej rodziny</h3>
        <p>Osobne grupy dla dzieci (7–14 lat) i dorosłych. Instruktorzy z certyfikatami PZA.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🎒</div>
        <h3>Sprzęt w cenie</h3>
        <p>Buty, uprzęże, kask — wszystko jest dostępne na miejscu. Przychodź w wygodnych ubraniach.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📅</div>
        <h3>Regularne terminy</h3>
        <p>Zajęcia w tygodniu i weekendy. Zapisy otwierają się 7 dni przed każdymi zajęciami.</p>
      </div>
    </div>
  </div>
</section>

<!-- SEKCJA: DZIECI vs DOROŚLI -->
<section class="section section--split">
  <div class="split-panel split-panel--kids">
    <div class="split-content">
      <div class="split-tag">Dla dzieci</div>
      <h2>Zajęcia dziecięce</h2>
      <p>Wiek 7–14 lat. Nauka podstaw wspinaczki w bezpiecznym środowisku pod okiem certyfikowanych instruktorów.</p>
      <ul class="split-list">
        <li>✓ Grupy max 10 osób</li>
        <li>✓ Sprzęt dostosowany do wzrostu</li>
        <li>✓ Elementy gier i zabaw</li>
        <li>✓ Certyfikat ukończenia</li>
      </ul>
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="/dashboard" class="btn btn--white">Zarezerwuj →</a>
      <% } else { %>
        <a href="/login" class="btn btn--white">Zaloguj się, aby zapisać →</a>
      <% } %>
    </div>
  </div>
  <div class="split-panel split-panel--adults">
    <div class="split-content">
      <div class="split-tag">Dla dorosłych</div>
      <h2>Zajęcia dla dorosłych</h2>
      <p>Wiek 18+. Od zupełnych początkujących po zaawansowanych techniki prowadzenia.</p>
      <ul class="split-list">
        <li>✓ Grupy max 12 osób</li>
        <li>✓ Różne poziomy trudności</li>
        <li>✓ Techniki asekuracji</li>
        <li>✓ Trening siłowy wspinaczkowy</li>
      </ul>
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="/dashboard" class="btn btn--white">Zarezerwuj →</a>
      <% } else { %>
        <a href="/login" class="btn btn--white">Zaloguj się, aby zapisać →</a>
      <% } %>
    </div>
  </div>
</section>

<!-- SEKCJA: NAJBLIŻSZE TERMINY -->
<% if (upcomingClasses.length > 0) { %>
<section class="section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Zarejestruj się</span>
      <h2>Najbliższe zajęcia</h2>
    </div>

    <div class="classes-grid">
      <% upcomingClasses.forEach(cls => { %>
        <%
          const date = new Date(cls.start_time);
          const dateStr = date.toLocaleDateString('pl-PL', { weekday: 'short', day: 'numeric', month: 'short' });
          const timeStr = date.toLocaleTimeString('pl-PL', { hour: '2-digit', minute: '2-digit' });
          const taken = cls.taken_spots || 0;
          const left = cls.max_spots - taken;
          const isOpen = isBookingOpen(cls.start_time);
          const openDate = getBookingOpenDate(cls.start_time);
        %>
        <div class="class-card <%= cls.category %>">
          <div class="class-card-header">
            <span class="class-category-badge">
              <%= cls.category === 'kids' ? '👶 Dzieci' : cls.category === 'adults' ? '🧑 Dorośli' : '👥 Mieszane' %>
            </span>
            <span class="class-spots <%= left <= 3 ? 'class-spots--low' : '' %>">
              <%= left > 0 ? `${left} miejsc` : 'Brak miejsc' %>
            </span>
          </div>
          <h3 class="class-card-name"><%= cls.name %></h3>
          <div class="class-card-meta">
            <span>📅 <%= dateStr %></span>
            <span>⏰ <%= timeStr %></span>
            <% if (cls.instructor) { %><span>👤 <%= cls.instructor %></span><% } %>
          </div>
          <div class="class-card-action">
            <% if (!isOpen) { %>
              <span class="class-locked">🔒 Zapisy od <%= openDate.toLocaleDateString('pl-PL', {day:'numeric', month:'short'}) %></span>
            <% } else if (left <= 0) { %>
              <span class="class-full">Brak miejsc</span>
            <% } else { %>
              <a href="/book/<%= cls.id %>" class="btn btn--primary btn--sm">Zapisz się</a>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>

    <div style="text-align:center;margin-top:2rem;">
      <a href="/calendar" class="btn btn--outline">Wszystkie terminy →</a>
    </div>
  </div>
</section>
<% } %>

<!-- SEKCJA: MAPA -->
<section class="section section--map">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Gdzie ćwiczymy</span>
      <h2>Skarpa Bytom Rozbark</h2>
    </div>
    <div class="map-wrapper">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2546.284345570785!2d18.928098576550873!3d50.34260167157167!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4716d34cb979d97f%3A0x55caf8fee26a2016!2sSkarpa%20Bytom%20Rozbark!5e0!3m2!1spl!2spl!4v1776429791392!5m2!1spl!2spl"
        width="100%" height="400" style="border:0;border-radius:12px;"
        allowfullscreen="" loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Skarpa Bytom Rozbark">
      </iframe>
      <div class="map-info-card">
        <h4>📍 KS "Skarpa Bytom"</h4>
        <p>Klub Sportowy<br>Skarpa Bytom Rozbark</p>
        <a href="https://maps.google.com/maps?ll=50.342602,18.9281&z=16&t=m&hl=pl&gl=PL&mapclient=embed&cid=6182064567221362710" target="_blank" rel="noopener" class="btn btn--primary btn--sm">
          Naviguj w Google Maps →
        </a>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section section--cta">
  <div class="container">
    <div class="cta-box">
      <div class="cta-content">
        <h2>Gotowy na zajęcia?</h2>
        <p>Zaloguj się do panelu i zarządzaj zapisanymi osobami.</p>
      </div>
      <div class="cta-actions">
        <% if (typeof user !== 'undefined' && user) { %>
          <a href="/dashboard" class="btn btn--white btn--lg">Twój Panel →</a>
        <% } else { %>
          <a href="/login" class="btn btn--white btn--lg">Zaloguj się / Zarejestruj →</a>
        <% } %>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>
