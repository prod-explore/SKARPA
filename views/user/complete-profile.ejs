<%- include('../partials/head') %>

<div class="auth-page">
  <div class="auth-side auth-side--visual">
    <div class="auth-visual-content">
      <a href="/" class="auth-brand">
        <img class="auth-brand-logo" src="/images/fw-logo.png" alt="" width="44" height="44" decoding="async">
        <span class="auth-brand-label">Panel uczestnika</span>
      </a>
      <div class="auth-visual-tagline">
        <h2>Prawie gotowe!</h2>
        <p>Uzupełnij swój profil, aby zapisywać się na zajęcia.</p>
      </div>
    </div>
  </div>

  <div class="auth-side auth-side--form">
    <div class="auth-form-wrapper">
      <h1 class="auth-title">Uzupełnij profil</h1>
      <p class="auth-subtitle">Podaj swoje dane. Potrzebujemy ich do listy uczestników.</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert--error"><%= error %></div>
      <% } %>

      <form action="/profile/complete" method="POST" class="auth-form">
        <input type="hidden" name="next" value="<%= typeof next !== 'undefined' ? next : '/dashboard' %>">

        <div class="form-row">
          <div class="form-group">
            <label for="firstName" class="form-label">Imię *</label>
            <input type="text" id="firstName" name="firstName" class="form-input"
                   placeholder="Jan" required autofocus autocomplete="given-name">
          </div>
          <div class="form-group">
            <label for="lastName" class="form-label">Nazwisko *</label>
            <input type="text" id="lastName" name="lastName" class="form-input"
                   placeholder="Kowalski" required autocomplete="family-name">
          </div>
        </div>

        <div class="form-group">
          <label for="birthDate" class="form-label">Data urodzenia *</label>
          <div class="form-input-with-label">
            <input type="date" id="birthDate" name="birthDate" class="form-input" required max="<%= new Date().toISOString().split('T')[0] %>">
            <span id="ageDisplay" class="age-badge" style="display:none;"></span>
          </div>
          <p class="auth-subtitle" style="margin-top: 0.5rem; font-size: 0.85rem;">Konto mogą utworzyć osoby w wieku minimum 16 lat. Młodsze dzieci rejestrują rodzice.</p>
        </div>

        <script>
          const birthDateInput = document.getElementById('birthDate');
          const ageDisplay = document.getElementById('ageDisplay');

          birthDateInput.addEventListener('change', function() {
            const birthDate = new Date(this.value);
            if (isNaN(birthDate.getTime())) {
              ageDisplay.style.display = 'none';
              birthDateInput.setCustomValidity('');
              return;
            }

            const today = new Date();
            let age = today.getFullYear() - birthDate.getFullYear();
            const m = today.getMonth() - birthDate.getMonth();
            if (m < 0 || (m === 0 && today.getDate() < birthDate.getDate())) {
              age--;
            }

            if (age >= 0) {
              ageDisplay.textContent = age + (age === 1 ? ' rok' : (age < 5 ? ' lata' : ' lat'));
              ageDisplay.style.display = 'inline-flex';
              ageDisplay.className = 'age-badge ' + (age >= 16 ? 'age-badge--adult' : 'age-badge--child');
              if (age < 16) {
                birthDateInput.setCustomValidity('Samodzielne konto mogą założyć osoby od 16 roku życia. Młodszych uczestników rejestrują rodzice ze swojego konta.');
              } else {
                birthDateInput.setCustomValidity('');
              }
            } else {
              ageDisplay.style.display = 'none';
              birthDateInput.setCustomValidity('');
            }
          });
        </script>

        <style>
          .form-input-with-label {
            position: relative;
            display: flex;
            align-items: center;
          }
          .age-badge {
            margin-left: 10px;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 700;
            white-space: nowrap;
          }
          .age-badge--adult { background: #e0f2fe; color: #0369a1; }
          .age-badge--child { background: #fef3c7; color: #92400e; }
        </style>

        <div class="auth-consents">
          <div class="consent-group">
            <label class="consent-checkbox">
              <input type="checkbox" name="terms_accepted" required>
              <span class="checkbox-custom"></span>
              <span class="consent-text">
                Akceptuję <a href="/terms" target="_blank">Regulamin</a> oraz <a href="/privacy" target="_blank">Politykę Prywatności</a>. *
              </span>
            </label>
          </div>
          <div class="consent-group">
            <label class="consent-checkbox">
              <input type="checkbox" name="marketing_accepted">
              <span class="checkbox-custom"></span>
              <span class="consent-text">
                Chcę otrzymywać informacje o nadchodzących terminach zajęć i nowościach (opcjonalne).
              </span>
            </label>
          </div>
        </div>

        <style>
          .auth-consents { margin: 1.5rem 0; display: flex; flex-direction: column; gap: 1rem; }
          .consent-group { display: flex; align-items: flex-start; }
          .consent-checkbox { display: flex; align-items: flex-start; gap: 12px; cursor: pointer; user-select: none; }
          .consent-checkbox input { position: absolute; opacity: 0; cursor: pointer; height: 0; width: 0; }
          .checkbox-custom { height: 20px; width: 20px; background-color: #eee; border-radius: 4px; flex-shrink: 0; position: relative; transition: all 0.2s; }
          .consent-checkbox:hover input ~ .checkbox-custom { background-color: #ccc; }
          .consent-checkbox input:checked ~ .checkbox-custom { background-color: #1a1d17; }
          .checkbox-custom:after { content: ""; position: absolute; display: none; left: 7px; top: 3px; width: 6px; height: 10px; border: solid white; border-width: 0 2px 2px 0; transform: rotate(45deg); }
          .consent-checkbox input:checked ~ .checkbox-custom:after { display: block; }
          .consent-text { font-size: 0.85rem; color: #444; line-height: 1.4; }
          .consent-text a { color: #1a1d17; font-weight: 600; text-decoration: underline; }
        </style>

        <button type="submit" class="btn btn--primary btn--full btn--lg">
          Zapisz i przejdź dalej →
        </button>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
</body>
</html>
