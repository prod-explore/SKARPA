<%- include('../partials/head') %>
<%- include('../partials/navbar', { user: user }) %>

<div class="page-content" style="text-align:center;padding:6rem 1rem;">
  <div class="container container--narrow">
    <% if (code === 404) { %>
      <img src="/images/fw-logo.png" alt="" class="error-page-logo" width="112" height="112" decoding="async">
    <% } else { %>
      <div class="error-page-icon" aria-hidden="true">⚠️</div>
    <% } %>
    <h1 style="font-size:6rem;font-weight:900;color:var(--primary);margin:0;line-height:1;"><%= code %></h1>
    <h2 style="margin:1rem 0 0.5rem;"><%= title %></h2>
    <p style="color:var(--text-muted);margin-bottom:2rem;"><%= message %></p>
    <a href="/" class="btn btn--primary">← Strona główna</a>
  </div>
</div>

<%- include('../partials/footer') %>
</body>
</html>
