  font-family: 'Barlow Condensed', sans-serif;
  color: var(--primary-dark);
  margin-bottom: 0.5rem;
}
.document-content h2 {
  font-family: 'Barlow Condensed', sans-serif;
  color: var(--primary);
  margin-top: 2rem;
  margin-bottom: 1rem;
}
.document-content p {
  color: var(--text);
  margin-bottom: 1rem;
  line-height: 1.7;
}
.document-content em { color: var(--text-muted); }
</style>

