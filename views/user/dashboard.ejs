<%- include('../partials/head') %>
<%- include('../partials/navbar', { user: user }) %>

<div class="dashboard">
  <div class="container">

    <!-- Header -->
    <div class="dashboard-header">
      <div>
        <h1>Cześć, <%= user.first_name %>! 👋</h1>
        <p class="dashboard-email"><%= user.email %></p>
        <% if (isMinor) { %>
          <span class="badge badge--info" style="margin-top:6px;display:inline-block;">👦 Konto niepełnoletniego</span>
        <% } %>
      </div>
      <% if (user.is_verified) { %>
        <a href="/calendar" class="btn btn--primary">+ Zapisz się na zajęcia</a>
      <% } %>
    </div>

    <!-- BLOKADA: Niezweryfikowane konto niepełnoletniego -->
    <% if (!user.is_verified) { %>
      <div class="consent-block">
        <div class="consent-block-icon">🔒</div>
        <h2>Wymagana zgoda rodzica</h2>
        <% if (user.consent_requested) { %>
          <p>Twoja prośba o weryfikację została wysłana. Oczekuj na zatwierdzenie przez administratora.</p>
          <div class="consent-status">
            <span class="badge badge--soon">⏳ Oczekuje na weryfikację</span>
          </div>
        <% } else { %>
          <p>Zanim będziesz mógł/mogła zapisywać się na zajęcia, potrzebujemy zgody Twojego rodzica lub opiekuna prawnego.</p>
          <p>Kliknij poniższy przycisk, aby wysłać prośbę o weryfikację do administratora. Następnie dostarcz podpisaną zgodę na miejscu lub skontaktuj się z nami.</p>
          <form action="/consent/request" method="POST" style="margin-top:1.5rem;">
            <button type="submit" class="btn btn--primary btn--lg">
              📋 Poproś o autoryzację konta
            </button>
          </form>
        <% } %>
        <p class="consent-contact">
          Pytania? Napisz na <a href="mailto:wspinanie.ue@gmail.com">wspinanie.ue@gmail.com</a>
        </p>
      </div>

    <% } else { %>
      <!-- Moje zapisy -->
      <section class="dashboard-section">
        <h2 class="dashboard-section-title">Moje zapisy</h2>

        <% if (bookings.length === 0) { %>
          <div class="empty-state">
            <div class="empty-state-icon empty-state-icon--logo">
              <img src="/images/fw-logo.png" alt="" width="96" height="96" decoding="async">
            </div>
            <h3>Nie masz jeszcze żadnych zapisów</h3>
            <p>Sprawdź dostępne terminy i zapisz się na pierwsze zajęcia.</p>
            <a href="/calendar" class="btn btn--primary">Zobacz kalendarz →</a>
          </div>
        <% } else { %>
          <div class="bookings-list">
            <% bookings.forEach(b => { %>
              <%
                const date = new Date(b.start_time);
                const dateStr = date.toLocaleDateString('pl-PL', { weekday: 'long', day: 'numeric', month: 'long' });
                const endDate = new Date(date.getTime() + (b.duration_min * 60000));
                const endTimeStr = endDate.toLocaleTimeString('pl-PL', { hour: '2-digit', minute: '2-digit' });
                const timeStr = date.toLocaleTimeString('pl-PL', { hour: '2-digit', minute: '2-digit' });
                const isPast = date < new Date();
                const hoursLeft = (date - new Date()) / (1000 * 60 * 60);
              %>
              <div class="booking-card <%= isPast ? 'booking-card--past' : '' %>">
                <div class="booking-card-left">
                  <div class="booking-date-block">
                    <span class="booking-day"><%= date.getDate() %></span>
                    <span class="booking-month"><%= date.toLocaleDateString('pl-PL', { month: 'short' }).replace('.','') %></span>
                  </div>
                </div>
                <div class="booking-card-body">
                  <h3 class="booking-class-name"><%= b.name %></h3>
                  <div class="booking-meta">
                    <span>⏰ <%= timeStr %> - <%= endTimeStr %></span>
                    <% if (b.instructor) { %><span>👤 <%= b.instructor %></span><% } %>
                  </div>
                  <div class="booking-participants">
                    <strong>Uczestnicy:</strong>
                    <% b.participants.forEach(p => { %>
                      <span class="participant-chip">
                        <%= p.first_name %> <%= p.last_name %>
                        <% if (p.is_main) { %> ★<% } %>
                        <% const age = p.child_age || p.age; %>
                        <% if (age != null) { %><span class="participant-chip-age">(<%= age %> lat)</span><% } %>
                        <% if (!isPast && hoursLeft >= 2 && b.participants.length > 1) { %>
                          <form action="/cancel/<%= b.class_id %>/participants/<%= p.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Czy na pewno chcesz wypisać tę osobę?')">
                            <button type="submit" style="background:none;border:none;color:var(--danger);cursor:pointer;margin-left:4px;padding:0;font-size:0.9em;" title="Wypisz uczestnika">✕</button>
                          </form>
                        <% } %>
                      </span>
                    <% }); %>
                  </div>
                </div>
                <div class="booking-card-action">
                  <% if (isPast) { %>
                    <span class="badge badge--past">Zakończone</span>
                  <% } else if (hoursLeft < 2) { %>
                    <span class="badge badge--soon">Za < 2h</span>
                  <% } else { %>
                    <form action="/cancel/<%= b.class_id %>" method="POST"
                          onsubmit="return confirm('Czy na pewno chcesz odwołać zapis?')">
                      <button type="submit" class="btn btn--danger btn--sm">Odwołaj</button>
                    </form>
                  <% } %>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </section>

      <!-- Lista rezerwowa użytkownika -->
      <% if (typeof waitlistBookings !== 'undefined' && waitlistBookings && waitlistBookings.length > 0) { %>
      <section class="dashboard-section">
        <h2 class="dashboard-section-title">🕐 Lista rezerwowa</h2>
        <div class="bookings-list">
          <% waitlistBookings.forEach(w => { %>
            <%
              const wDate = new Date(w.start_time);
              const wDateStr = wDate.toLocaleDateString('pl-PL', { weekday: 'long', day: 'numeric', month: 'long' });
              const wTimeStr = wDate.toLocaleTimeString('pl-PL', { hour: '2-digit', minute: '2-digit' });
              const wEndDate = new Date(wDate.getTime() + (w.duration_min * 60000));
              const wEndTimeStr = wEndDate.toLocaleTimeString('pl-PL', { hour: '2-digit', minute: '2-digit' });
            %>
            <div class="booking-card" style="border-left: 3px solid #f59e0b;">
              <div class="booking-card-left">
                <div class="booking-date-block">
                  <span class="booking-day"><%= wDate.getDate() %></span>
                  <span class="booking-month"><%= wDate.toLocaleDateString('pl-PL', { month: 'short' }).replace('.','') %></span>
                </div>
              </div>
              <div class="booking-card-body">
                <h3 class="booking-class-name"><%= w.name %></h3>
                <div class="booking-meta">
                  <span>⏰ <%= wTimeStr %> - <%= wEndTimeStr %></span>
                  <% if (w.instructor) { %><span>👤 <%= w.instructor %></span><% } %>
                </div>
                <div style="margin-top:8px;">
                  <span style="display:inline-block;background:#fef3c7;color:#92400e;font-size:12px;font-weight:600;padding:3px 10px;border-radius:20px;border:1px solid #fde68a;">
                    🕐 Na liście rezerwowej
                  </span>
                  <p style="margin:6px 0 0;font-size:13px;color:#666;">Zostaniesz powiadomiony e-mailem gdy zwolni się miejsce.</p>
                </div>
              </div>
              <div class="booking-card-action">
                <form action="/waitlist/cancel/<%= w.class_id %>" method="POST"
                      onsubmit="return confirm('Czy na pewno chcesz wypisać się z listy rezerwowej?')">
                  <button type="submit" class="btn btn--outline btn--sm" style="border-color:#f59e0b;color:#92400e;">Wypisz się</button>
                </form>
              </div>
            </div>
          <% }); %>
        </div>
      </section>
      <% } %>

      <!-- Dostępne terminy — widok tygodniowy -->
      <section class="dashboard-section">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;padding-bottom:.75rem;border-bottom:2px solid var(--border);">
          <h2 class="dashboard-section-title" style="margin:0;border:none;padding:0;">Dostępne terminy</h2>
          <div class="week-nav" style="gap:.5rem;flex-wrap:nowrap;">
            <a href="/dashboard?week=<%= weekOffset - 1 %>" class="btn btn--outline btn--xs">←</a>
            <span style="font-size:.85rem;font-weight:600;white-space:nowrap;color:var(--text-muted);">
              <%= weekStart.toLocaleDateString('pl-PL',{day:'numeric',month:'short'}) %> – <%= weekEnd.toLocaleDateString('pl-PL',{day:'numeric',month:'short',year:'numeric'}) %>
            </span>
            <a href="/dashboard?week=<%= weekOffset + 1 %>" class="btn btn--outline btn--xs">→</a>
          </div>
        </div>

        <% if (weekClasses.length === 0) { %>
          <div class="empty-state">
            <div class="empty-state-icon">📅</div>
            <h3>Brak dostępnych zajęć w tym tygodniu</h3>
            <p>Sprawdź inny tydzień lub wróć wkrótce — nowe terminy są dodawane na bieżąco.</p>
          </div>
        <% } else { %>
          <%
            /* ========== PRE-PROCESSING: group events by day, detect overlaps ========== */
            const PX_PER_HOUR = 64;
            const totalHours = END_HOUR - START_HOUR;
            const gridHeight = totalHours * PX_PER_HOUR;

            /* Build per-day arrays */
            const dayEvents = [[], [], [], [], [], [], []];

            weekClasses.forEach(cls => {
              const st = new Date(cls.start_time);
              const dayInWeek = Math.round(
                (new Date(weekStart.toDateString()) - new Date(st.toDateString())) / 86400000
              ) * -1;
              if (dayInWeek < 0 || dayInWeek > 6) return;

              const startMin = st.getHours() * 60 + st.getMinutes();
              const endMin   = startMin + (cls.duration_min || 60);
              const offsetMin = startMin - START_HOUR * 60;
              if (offsetMin < 0) return;

              const et = new Date(st.getTime() + (cls.duration_min || 60) * 60000);
              const timeStr = st.toLocaleTimeString('pl-PL', { hour: '2-digit', minute: '2-digit' });
              const endStr  = et.toLocaleTimeString('pl-PL', { hour: '2-digit', minute: '2-digit' });

              const adultLeft = cls.max_spots - (cls.adult_taken || 0);
              const childLeft = cls.class_type === 'adult_and_child'
                ? (cls.max_child_spots - (cls.child_taken || 0)) : 0;

              dayEvents[dayInWeek].push({
                id:               cls.id,
                name:             cls.name,
                instructor:       cls.instructor || '',
                child_instructor: cls.child_instructor || '',
                description:      cls.description || '',
                class_type:       cls.class_type,
                is_cancelled:     cls.is_cancelled,
                max_spots:        cls.max_spots,
                max_child_spots:  cls.max_child_spots,
                duration_min:     cls.duration_min || 60,
                color:            cls.color || '#6366f1',
                startMin, endMin, offsetMin, timeStr, endStr,
                adultLeft, childLeft,
                isFull: adultLeft <= 0,
                col: 0,
                totalCols: 1
              });
            });

            /* Overlap detection: greedy column assignment per day */
            dayEvents.forEach(events => {
              events.sort((a, b) => a.startMin - b.startMin || a.endMin - b.endMin);

              const columns = []; /* columns[c] = [events...] */
              events.forEach(ev => {
                let placed = false;
                for (let c = 0; c < columns.length; c++) {
                  const last = columns[c][columns[c].length - 1];
                  if (last.endMin <= ev.startMin) {
                    columns[c].push(ev);
                    ev.col = c;
                    placed = true;
                    break;
                  }
                }
                if (!placed) {
                  ev.col = columns.length;
                  columns.push([ev]);
                }
              });

              /* Compute totalCols per overlap cluster */
              events.forEach(ev => {
                let maxCol = ev.col;
                events.forEach(other => {
                  if (other.startMin < ev.endMin && other.endMin > ev.startMin) {
                    if (other.col > maxCol) maxCol = other.col;
                  }
                });
                ev.totalCols = maxCol + 1;
              });
            });
          %>

          <!-- ========== WEEKLY GRID ========== -->
          <div class="kcal-wrapper">
            <!-- Scrollable area: headers + body together -->
            <div class="kcal-scroll">
              <!-- Header row: gutter + 7 days -->
              <div class="kcal-header">
                <div class="kcal-gutter-hd"></div>
                <% for (let d = 0; d < 7; d++) {
                  const day = new Date(weekStart);
                  day.setDate(weekStart.getDate() + d);
                  const isToday = day.toDateString() === new Date().toDateString();
                %>
                <div class="kcal-day-hd <%= isToday ? 'kcal-day-hd--today' : '' %>">
                  <span class="kcal-day-name"><%= day.toLocaleDateString('pl-PL', { weekday: 'short' }) %></span>
                  <span class="kcal-day-num <%= isToday ? 'kcal-day-num--today' : '' %>"><%= day.getDate() %></span>
                </div>
                <% } %>
              </div>
              <div class="kcal-body" style="height:calc(var(--hh) * <%= totalHours %>);">
                <!-- Time gutter -->
                <div class="kcal-gutter">
                  <% for (let h = START_HOUR; h < END_HOUR; h++) { %>
                  <div class="kcal-gutter-label" style="top:calc(var(--hh) * <%= h - START_HOUR %>);">
                    <%= String(h).padStart(2, '0') %>:00
                  </div>
                  <% } %>
                </div>

                <!-- 7 day columns -->
                <div class="kcal-cols">
                  <% for (let d = 0; d < 7; d++) {
                    const day = new Date(weekStart);
                    day.setDate(weekStart.getDate() + d);
                    const isToday = day.toDateString() === new Date().toDateString();
                  %>
                  <div class="kcal-col <%= isToday ? 'kcal-col--today' : '' %>">
                    <!-- Hour gridlines -->
                    <% for (let h = 0; h <= totalHours; h++) { %>
                    <div class="kcal-gridline" style="top:calc(var(--hh) * <%= h %>);"></div>
                    <% } %>
                    <!-- Half-hour gridlines -->
                    <% for (let h = 0; h < totalHours; h++) { %>
                    <div class="kcal-gridline kcal-gridline--half" style="top:calc(var(--hh) * <%= h %> + var(--hh) * 0.5);"></div>
                    <% } %>

                    <!-- Events for this day -->
                    <% dayEvents[d].forEach(ev => {
                      const topMult    = (ev.offsetMin / 60);
                      const heightMult = (ev.duration_min / 60);
                      const colW     = 100 / ev.totalCols;
                      const leftPct  = ev.col * colW;
                    %>
                    <div class="kcal-ev <%= ev.isFull ? 'kcal-ev--full' : '' %> <%= ev.is_cancelled ? 'kcal-ev--cancelled' : '' %>"
                         style="
                           top:calc(var(--hh) * <%= topMult.toFixed(4) %>);
                           height:calc(var(--hh) * <%= heightMult.toFixed(4) %>);
                           left:calc(<%= leftPct.toFixed(2) %>% + 2px);
                           width:calc(<%= colW.toFixed(2) %>% - 4px);
                           --ev-color:<%= ev.color %>;
                         "
                         data-id="<%= ev.id %>"
                         data-name="<%= ev.name %>"
                         data-time="<%= ev.timeStr %> – <%= ev.endStr %>"
                         data-instructor="<%= ev.instructor %>"
                         data-child-instructor="<%= ev.child_instructor %>"
                         data-description="<%= ev.description %>"
                         data-adult-left="<%= ev.adultLeft %>"
                         data-adult-max="<%= ev.max_spots %>"
                         data-child-left="<%= ev.childLeft %>"
                         data-child-max="<%= ev.max_child_spots %>"
                         data-type="<%= ev.class_type %>"
                         data-cancelled="<%= ev.is_cancelled ? '1' : '0' %>"
                         role="button" tabindex="0" aria-label="<%= ev.name %>"
                    >
                      <span class="kcal-ev-name"><%= ev.name %></span>
                      <span class="kcal-ev-time"><%= ev.timeStr %> – <%= ev.endStr %></span>
                      <% if (ev.instructor) { %>
                      <span class="kcal-ev-instr"><%= ev.instructor %></span>
                      <% } %>
                      <% if (ev.isFull) { %>
                      <span class="kcal-ev-badge">Brak miejsc</span>
                      <% } else if (ev.is_cancelled) { %>
                      <span class="kcal-ev-badge">Odwołane</span>
                      <% } %>
                    </div>
                    <% }); %>
                  </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div><!-- .kcal-wrapper -->
        <% } %>
      </section>
    <% } %>

  </div>
</div>

<!-- MODAL SZCZEGÓŁÓW -->
<div id="classModal" class="cal-modal-overlay" aria-modal="true" role="dialog" style="display:none;">
  <div class="cal-modal">
    <button class="cal-modal-close" id="modalClose" aria-label="Zamknij">✕</button>
    <div class="cal-modal-accent" id="modalAccent"></div>
    <div class="cal-modal-body">
      <h2 class="cal-modal-title" id="modalTitle"></h2>
      <p class="cal-modal-time" id="modalTime"></p>

      <div class="cal-modal-meta" id="modalMeta"></div>
      <p class="cal-modal-desc" id="modalDesc"></p>

      <div class="cal-modal-spots" id="modalSpots"></div>

      <div class="cal-modal-actions" id="modalActions"></div>
    </div>
  </div>
</div>

<script>
  /* ── Modal logic ───────────────────────────────────────── */
  const modal        = document.getElementById('classModal');
  const modalClose   = document.getElementById('modalClose');
  const modalAccent  = document.getElementById('modalAccent');
  const modalTitle   = document.getElementById('modalTitle');
  const modalTime    = document.getElementById('modalTime');
  const modalMeta    = document.getElementById('modalMeta');
  const modalDesc    = document.getElementById('modalDesc');
  const modalSpots   = document.getElementById('modalSpots');
  const modalActions = document.getElementById('modalActions');
  const isLoggedIn   = <%= typeof user !== 'undefined' && user ? 'true' : 'false' %>;

  function openModal(el) {
    const d = el.dataset;
    const isCancelled = d.cancelled === '1';
    const adultLeft   = parseInt(d.adultLeft);
    const childLeft   = parseInt(d.childLeft);
    const isFull      = adultLeft <= 0;
    const isMixed     = d.type === 'adult_and_child';

    modalAccent.style.background = getComputedStyle(el).getPropertyValue('--ev-color');
    modalTitle.textContent = d.name;
    modalTime.textContent  = d.time;

    let meta = '';
    if (d.instructor)      meta += `<span>👤 ${d.instructor}</span>`;
    if (d.childInstructor) meta += `<span>🧒 Animacje: ${d.childInstructor}</span>`;
    meta += `<span>${isMixed ? '👥 Dorośli + Dzieci' : '🧑 Tylko dorośli'}</span>`;
    modalMeta.innerHTML = meta;

    const fullDesc = d.description || '';
    if (fullDesc.length > 250) {
      const shortDesc = fullDesc.substring(0, 250) + '... ';
      modalDesc.innerHTML = '';
      const textSpan = document.createElement('span');
      textSpan.textContent = shortDesc;
      const moreBtn = document.createElement('a');
      moreBtn.textContent = 'Pokaż więcej';
      moreBtn.style.cursor = 'pointer';
      moreBtn.style.color = 'var(--brand)';
      moreBtn.style.fontWeight = '700';
      moreBtn.onclick = () => {
        textSpan.textContent = fullDesc;
        moreBtn.style.display = 'none';
      };
      modalDesc.appendChild(textSpan);
      modalDesc.appendChild(moreBtn);
      modalDesc.style.display = '';
    } else {
      modalDesc.textContent = fullDesc;
      modalDesc.style.display = fullDesc ? '' : 'none';
    }

    let spots = `<div class="modal-spots-row">`;
    spots += `<span class="modal-spot-label ${adultLeft <= 3 ? 'low' : ''}">🧑 Dorośli: ${adultLeft} wolnych</span>`;
    if (isMixed) {
      spots += `<span class="modal-spot-label ${childLeft <= 3 ? 'low' : ''}">👦 Dzieci: ${childLeft} wolnych</span>`;
    }
    spots += `</div>`;
    modalSpots.innerHTML = spots;

    let actions = '';
    if (isCancelled) {
      actions = `<span class="badge badge--full">Zajęcia odwołane</span>`;
    } else if (isFull) {
      actions = `<span class="badge badge--full">Brak miejsc</span>`;
    } else if (isLoggedIn) {
      actions = `<a href="/book/${d.id}" class="btn btn--primary btn--lg">Zapisz się →</a>`;
    } else {
      actions = `<a href="/login?next=/book/${d.id}" class="btn btn--primary btn--lg">Zaloguj się, by się zapisać →</a>`;
    }
    modalActions.innerHTML = actions;

    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    modalClose.focus();
  }

  function closeModal() {
    modal.style.display = 'none';
    document.body.style.overflow = '';
  }

  /* Bind events */
  document.querySelectorAll('.kcal-ev').forEach(el => {
    el.addEventListener('click', () => openModal(el));
    el.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openModal(el); } });
  });

  modalClose.addEventListener('click', closeModal);
  modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>

<%- include('../partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>

